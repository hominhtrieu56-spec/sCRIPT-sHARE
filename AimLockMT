local function removeESP()

    if targetHighlight then
        targetHighlight:Destroy()
        targetHighlight = nil
    end

    if targetBillboard then
        targetBillboard:Destroy()
        targetBillboard = nil
    end
end

local function createESP(target)

    removeESP()

    if not target
    or not target.Character then
        return
    end

    local character = target.Character

    local highlight = Instance.new("Highlight")
    highlight.Parent = character
    highlight.FillColor = Color3.fromRGB(255,0,0)
    highlight.OutlineColor = Color3.fromRGB(255,255,255)
    highlight.FillTransparency = 0.45
    highlight.DepthMode =
        Enum.HighlightDepthMode.AlwaysOnTop

    targetHighlight = highlight

    local head =
        character:FindFirstChild("Head")
        or character:FindFirstChild(AIM_PART)

    if head then

        local billboard =
            Instance.new("BillboardGui")

        billboard.Parent = head
        billboard.Size =
            UDim2.new(0,140,0,40)

        billboard.AlwaysOnTop = true
        billboard.StudsOffset =
            Vector3.new(0,2.5,0)

    end
end

-- =========================
-- FUNCTIONS
-- =========================
local function isVisible(targetPart)

    if not WALL_CHECK then
        return true
    end

    local origin = camera.CFrame.Position
    local direction = (targetPart.Position - origin)

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {player.Character}
    params.IgnoreWater = true

    local result = workspace:Raycast(
        origin,
        direction,
        params
    )

    if not result then
        return true
    end

    if result.Instance
    and result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end

    return false
end

local function getClosestTarget()

    local closest = nil
    local shortestDistance = FOV_RADIUS

    for _,v in pairs(Players:GetPlayers()) do

        if v ~= player
        and v.Character
        and v.Character:FindFirstChild(AIM_PART) then

            local humanoid =
                v.Character:FindFirstChildOfClass("Humanoid")

            if humanoid and humanoid.Health > 0 then

                if TEAM_CHECK and v.Team == player.Team then
                    continue
                end

                local aimPart = v.Character[AIM_PART]

                if not isVisible(aimPart) then
                    continue
                end

                local pos,visible =
                    camera:WorldToViewportPoint(
                        aimPart.Position
                    )

                if visible then

                    local distance =
                        (
                            Vector2.new(pos.X,pos.Y)
                            -
                            Vector2.new(
                                UserInputService:GetMouseLocation().X,
                                UserInputService:GetMouseLocation().Y
                            )
                        ).Magnitude

                    local worldDistance =
                        (
                            camera.CFrame.Position
                            -
                            aimPart.Position
                        ).Magnitude

                    if distance < shortestDistance
                    and worldDistance <= MAX_DISTANCE then

                        shortestDistance = distance
                        closest = v
                    end
                end
            end
        end
    end

    return closest
end

-- =========================
-- INPUT
-- =========================
UserInputService.InputBegan:Connect(function(input,gp)

    if gp then
        return
    end

    if input.UserInputType ==
        Enum.UserInputType.MouseButton2 then

        holding = true
    end

    if input.UserInputType ==
        Enum.UserInputType.MouseButton1 then

        shooting = true
    end

    if input.KeyCode == Enum.KeyCode.RightControl then

        menuVisible = not menuVisible

        main.Visible = menuVisible
        openButton.Visible = not menuVisible
    end

    if input.KeyCode == Enum.KeyCode.l then

        aimlockEnabled = not aimlockEnabled

        if not aimlockEnabled then
            removeESP()
        end

        aimButton.Text =
            "Aimlock 💻: " ..
            (aimlockEnabled and "ON" or "OFF")

        aimButton.BackgroundColor3 =
            aimlockEnabled
            and Color3.fromRGB(255,0,0)
            or Color3.fromRGB(35,35,35)
    end
end)

UserInputService.InputEnded:Connect(function(input)

    if input.UserInputType ==
        Enum.UserInputType.MouseButton2 then

        holding = false
    end

    if input.UserInputType ==
        Enum.UserInputType.MouseButton1 then

        shooting = false
    end
end)

