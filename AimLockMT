RunService.RenderStepped:Connect(function()

	if not espEnabled then
		return
	end

	if not player.Character then
		return
	end

	local myRoot =
		player.Character:FindFirstChild(
			"HumanoidRootPart"
		)

	if not myRoot then
		return
	end

	for target,data in pairs(espTable) do

		if data.humanoid
		and data.healthBar
		and data.distanceText
		and target.Character then

			local hum = data.humanoid

			local hp =
				math.clamp(
					hum.Health / hum.MaxHealth,
					0,
					1
				)

			data.healthBar.Size =
				UDim2.new(hp,0,1,0)

			-- màu máu
			if hp > 0.6 then

				data.healthBar.BackgroundColor3 =
					Color3.fromRGB(0,255,0)

			elseif hp > 0.3 then

				data.healthBar.BackgroundColor3 =
					Color3.fromRGB(255,170,0)

			else

				data.healthBar.BackgroundColor3 =
					Color3.fromRGB(255,0,0)
			end

			-- khoảng cách
			local distance =
				(
					myRoot.Position
					-
					data.root.Position
				).Magnitude

			data.distanceText.Text =
				math.floor(distance).."m"
		end
	end
end)
