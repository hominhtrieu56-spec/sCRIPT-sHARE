local autoAimEnabled = false
local lockedTarget = nil

local AUTO_AIM_STRENGTH = 0.22
local TARGET_SWITCH_DELAY = 0.15

local lastSwitch = 0

local autoAimButton =
	createButton("Aimlock 📱 : OFF",160)

autoAimButton.MouseButton1Click:Connect(function()

	autoAimEnabled = not autoAimEnabled

	if not autoAimEnabled then
		lockedTarget = nil
	end

	autoAimButton.Text =
		"Aimlock 📱: " ..
		(autoAimEnabled and "ON" or "OFF")

	autoAimButton.BackgroundColor3 =
		autoAimEnabled
		and Color3.fromRGB(255,0,0)
		or Color3.fromRGB(35,35,35)
end)

-- =========================
-- VALID TARGET
-- =========================

local function isTargetValid(target)

	if not target
	or not target.Character then
		return false
	end

	local humanoid =
		target.Character:FindFirstChildOfClass(
			"Humanoid"
		)

	local aimPart =
		target.Character:FindFirstChild(
			AIM_PART
		)

	if not humanoid
	or humanoid.Health <= 0
	or not aimPart then
		return false
	end

	-- team check
	if TEAM_CHECK
	and target.Team == player.Team then
		return false
	end

	-- wall check
	if not isVisible(aimPart) then
		return false
	end

	return true
end

-- =========================
-- AUTO AIM LOOP
-- =========================

RunService.RenderStepped:Connect(function()

	if not autoAimEnabled then
		return
	end

	-- giữ target ổn định
	if not isTargetValid(lockedTarget) then

		if tick() - lastSwitch >
			TARGET_SWITCH_DELAY then

			lockedTarget =
				getClosestTarget()

			lastSwitch = tick()
		end
	end

	if not isTargetValid(lockedTarget) then
		return
	end

	local aimPart =
		lockedTarget.Character:FindFirstChild(
			AIM_PART
		)

	if not aimPart then
		return
	end

	local velocity =
		aimPart.AssemblyLinearVelocity

	-- prediction mượt hơn mobile
	local predictedPosition =
		aimPart.Position
		+
		Vector3.new(
			velocity.X * 0.135,
			velocity.Y * 0.03,
			velocity.Z * 0.135
		)

	-- kéo tâm lên ngực/head
	predictedPosition =
		predictedPosition
		+
		Vector3.new(0,1.05,0)

	local aimCF =
		CFrame.lookAt(
			camera.CFrame.Position,
			predictedPosition
		)

	-- aim siêu ổn định
	camera.CFrame =
		camera.CFrame:Lerp(
			aimCF,
			AUTO_AIM_STRENGTH
		)
end)

