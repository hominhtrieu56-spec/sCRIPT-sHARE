-- =========================
-- MAIN LOOP
-- =========================
RunService.RenderStepped:Connect(function()

    circle.Position = Vector2.new(
        UserInputService:GetMouseLocation().X,
        UserInputService:GetMouseLocation().Y
    )

    local oldTarget = currentTarget

    currentTarget = getClosestTarget()

    if aimlockEnabled then

        if currentTarget ~= oldTarget then

            removeESP()

            if currentTarget then
                createESP(currentTarget)
            end
        end
    else
        removeESP()
    end

    if currentTarget
    and currentTarget.Character
    and currentTarget.Character:FindFirstChild(AIM_PART) then

        local aimPart =
            currentTarget.Character[AIM_PART]

        if not isVisible(aimPart) then
            return
        end

        local velocity =
            aimPart.AssemblyLinearVelocity

        local predictedPosition =
            aimPart.Position
            +
            Vector3.new(
                velocity.X * PREDICTION,
                velocity.Y * 0.015,
                velocity.Z * PREDICTION
            )

        predictedPosition =
            predictedPosition
            +
            Vector3.new(0,0.85,0)

        local aimCF =
            CFrame.lookAt(
                camera.CFrame.Position,
                predictedPosition
            )

        if aimlockEnabled and holding then

            camera.CFrame =
                camera.CFrame:Lerp(
                    aimCF,
                    AIMLOCK_STRENGTH
                )
        end

        if fovAimEnabled and shooting then

            camera.CFrame =
                camera.CFrame:Lerp(
                    aimCF,
                    FOV_AIM_STRENGTH
                )
        end
    end
end)
