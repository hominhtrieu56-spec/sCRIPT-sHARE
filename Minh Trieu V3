local function getPos(part)
	if not part then return nil,false end
	local pos, vis = Camera:WorldToViewportPoint(part.Position)
	return Vector2.new(pos.X,pos.Y), vis
end

local function createLine()
	local line = Drawing.new("Line")
	line.Thickness = 2
	line.Transparency = 1
	line.Visible = false
	return line
end

local function removeSkeleton(player)
	if skeletonTable[player] then
		for _,line in pairs(skeletonTable[player]) do
			line:Remove()
		end
		skeletonTable[player] = nil
	end
end

local function setupSkeleton(player)
	if player == LocalPlayer then return end
	if skeletonTable[player] then return end

	skeletonTable[player] = {
		Head = createLine(),
		LeftArm = createLine(),
		RightArm = createLine(),
		LeftLeg = createLine(),
		RightLeg = createLine()
	}
end

