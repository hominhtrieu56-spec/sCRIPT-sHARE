RangeTeleportButton.MouseButton1Click:Connect(function()

	teleportLoop = not teleportLoop

	if teleportLoop then

		RangeTeleportButton.Text = "Teleport : ON"
		RangeTeleportButton.BackgroundColor3 = Color3.fromRGB(0,170,0)

		if flying then return end
		flying = true

		local player = Players.LocalPlayer
		local character = player.Character or player.CharacterAdded:Wait()
		local root = character:WaitForChild("HumanoidRootPart")
		local humanoid = character:WaitForChild("Humanoid")

		local function equipWeapon()
			local tool = player.Backpack:FindFirstChildOfClass("Tool")
			if tool then
				humanoid:EquipTool(tool)
			end
		end

		equipWeapon()

		local bv = Instance.new("BodyVelocity")
		bv.MaxForce = Vector3.new(100000,100000,100000)
		bv.Velocity = Vector3.new(0,0,0)
		bv.Parent = root

		local bg = Instance.new("BodyGyro")
		bg.MaxTorque = Vector3.new(100000,100000,100000)
		bg.P = 10000
		bg.CFrame = root.CFrame
		bg.Parent = root

		local range = 67
		local speed = 90

		heartbeatConnection = RunService.Heartbeat:Connect(function()

			if not teleportLoop then
				bv:Destroy()
				bg:Destroy()
				flying = false
				if heartbeatConnection then
					heartbeatConnection:Disconnect()
				end
				return
			end

			local closestPlayer = nil
			local closestDistance = range
			local alivePlayers = 0

			for _,target in pairs(Players:GetPlayers()) do
				
				if target ~= player 
				and target.Character
				and target.Character:FindFirstChild("HumanoidRootPart")
				and target.Character:FindFirstChild("Humanoid")
				and target.Character.Humanoid.Health > 0 then
					
					alivePlayers += 1

					local targetRoot = target.Character.HumanoidRootPart

					if not targetRoot:FindFirstChild("HitboxExpand") then
						
						targetRoot.Size = Vector3.new(8,8,8)
						targetRoot.Transparency = 0.5
						targetRoot.Material = Enum.Material.Neon
						targetRoot.BrickColor = BrickColor.new("Bright blue")
						targetRoot.CanCollide = false

						local tag = Instance.new("BoolValue")
						tag.Name = "HitboxExpand"
						tag.Parent = targetRoot
						
					end

					local distance = (root.Position - targetRoot.Position).Magnitude
					
					if distance < closestDistance then
						closestDistance = distance
						closestPlayer = targetRoot
					end
					
				end
				
			end

			if alivePlayers == 0 then
				
				teleportLoop = false
				RangeTeleportButton.Text = "Teleport : OFF"
				RangeTeleportButton.BackgroundColor3 = Color3.fromRGB(170,0,0)

				bv:Destroy()
				bg:Destroy()
				flying = false

				if heartbeatConnection then
					heartbeatConnection:Disconnect()
				end

				return
			end

			if closestPlayer then

				local targetPos = closestPlayer.Position + Vector3.new(0,4,0)
				local direction = (targetPos - root.Position).Unit
				
				bv.Velocity = direction * speed

				if closestDistance <= 15 then
					
					local tool = character:FindFirstChildOfClass("Tool")
					
					if tool then
						tool:Activate()
					else
						equipWeapon()
					end
					
				end

			else
				bv.Velocity = Vector3.new(0,0,0)
			end

