RunService.RenderStepped:Connect(function()
	if not espEnabled then return end
	if not LocalPlayer.Character then return end

	local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not myRoot then return end

	rainbowHue += 0.005
	if rainbowHue > 1 then rainbowHue = 0 end
	local rainbowColor = Color3.fromHSV(rainbowHue,1,1)

	for player,data in pairs(espTable) do
		if data.root and data.label and data.humanoid then

			local char = player.Character

			if not char or not char.Parent or data.humanoid.Health <= 0 then
				removeSkeleton(player)
				continue
			end

			local distance = (myRoot.Position - data.root.Position).Magnitude
			local hp = math.floor(data.humanoid.Health)

			data.label.Text = player.Name..
				"\nHP: "..hp..
				"\n"..math.floor(distance).."m"

			data.highlight.FillColor = rainbowColor
			data.highlight.OutlineColor = rainbowColor
			data.rootHighlight.FillColor = rainbowColor
			data.rootHighlight.OutlineColor = rainbowColor

			local invisible = true
			for _,v in pairs(char:GetDescendants()) do
				if v:IsA("BasePart") and v.Transparency < 1 then
					invisible = false
					break
				end
			end

			if invisible then
				data.highlight.FillTransparency = 1
				data.rootHighlight.FillTransparency = 0.2
			else
				data.highlight.FillTransparency = 0.5
				data.rootHighlight.FillTransparency = 1
			end


			if not skeletonTable[player] then
				setupSkeleton(player)
			end

			local lines = skeletonTable[player]

			local head = char:FindFirstChild("Head")
			local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
			local la = char:FindFirstChild("LeftUpperArm") or char:FindFirstChild("Left Arm")
			local ra = char:FindFirstChild("RightUpperArm") or char:FindFirstChild("Right Arm")
			local ll = char:FindFirstChild("LeftUpperLeg") or char:FindFirstChild("Left Leg")
			local rl = char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg")

			if not (head and torso) then
				for _,l in pairs(lines) do l.Visible = false end
				continue
			end

			local hPos,hVis = getPos(head)
			local tPos,tVis = getPos(torso)
			local laPos,laVis = getPos(la)
			local raPos,raVis = getPos(ra)
			local llPos,llVis = getPos(ll)
			local rlPos,rlVis = getPos(rl)

			local function draw(line,p1,v1,p2,v2)
				if v1 and v2 then
					line.From = p1
					line.To = p2
					line.Color = rainbowColor
					line.Visible = true
				else
					line.Visible = false
				end
			end

			draw(lines.Head, hPos, hVis, tPos, tVis)
			draw(lines.LeftArm, tPos, tVis, laPos, laVis)
			draw(lines.RightArm, tPos, tVis, raPos, raVis)
			draw(lines.LeftLeg, tPos, tVis, llPos, llVis)
			draw(lines.RightLeg, tPos, tVis, rlPos, rlVis)
		end
	end
end)

function enableESP()
	for _,player in pairs(Players:GetPlayers()) do
		setupPlayer(player)
	end
end

function disableESP()
	for player,data in pairs(espTable) do
		if data.part then data.part:Destroy() end
		removeSkeleton(player)
	end
	espTable = {}
end

